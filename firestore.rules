rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isAuth();
      allow create, update, delete: if isOwner(uid);
    }

    match /projects/{projectId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.ownerUid == request.auth.uid;
    }

    match /messages/{messageId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid == request.resource.data.senderUid && request.auth.uid in request.resource.data.participants;
      allow update, delete: if false;
    }
  }
}
